# Copie para .env e ajuste antes de rodar os testes.
# PowerShell: Copy-Item config.env.example .env

# URL base da aplicação Spring (sem barra final)
BASE_URL=http://localhost:8080

# Ocorrências (POST) — usuário já cadastrado no MySQL
K6_USER_EMAIL=carga@edu.unirio.br
K6_USER_PASSWORD=altere-a-senha

# Linha existente na tabela `linha` (ex.: 636 do GTFS/SPPO)
K6_LINHA=636

# Tipo de ocorrência: SUPERLOTACAO | ATRASO | ACIDENTE | INTERRUPCAO
K6_OCORRENCIA_TIPO=ATRASO
