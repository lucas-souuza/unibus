# Copie para unibus-app/src/main/resources/application.properties
# Ajuste username/password do seu MySQL local (porta padrão 3306).

spring.application.name=unibus-app

spring.datasource.url=jdbc:mysql://localhost:3306/unibus
spring.datasource.username=root
spring.datasource.password=COLOQUE_SUA_SENHA

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

server.port=8080

unibus.sppo.base-url=https://dados.mobilidade.rio
unibus.sppo.gps-path=/gps/sppo
unibus.sppo.connect-timeout-ms=10000
unibus.sppo.read-timeout-ms=120000
unibus.sppo.janela-segundos=180

unibus.gtfs.routes.classpath-location=classpath:data/gtfs/routes.txt
